{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Ag Census MR TMR Compiler",
    "version":  "1.0.0",
    "identifier":  "org.fao.agcensus.compiler",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build:scripts \u0026\u0026 npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Ag Census MR TMR Compiler",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  960,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "publisher":  "D. Bako",
                   "targets":  [
                                   "msi",
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "../dist-scripts/":  "dist-scripts/",
                                     "../node_modules/tesseract.js/dist/tesseract.esm.min.js":  "node_modules/tesseract.js/dist/",
                                     "../node_modules/tesseract.js/dist/worker.min.js":  "node_modules/tesseract.js/dist/"
                                 },
                   "windows":  {
                                   "wix":  {
                                               "language":  "en-US"
                                           },
                                   "nsis":  {
                                                "installMode":  "currentUser"
                                            }
                               }
               }
}